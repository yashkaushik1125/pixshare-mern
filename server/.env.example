# ---------------------------------------------------------------------------
# Server configuration
# ---------------------------------------------------------------------------
PORT=4000

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/pixshare
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/pixshare?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/pixshare

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS: where the React client is served from
CLIENT_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# App branding (served to the client via GET /api/config)
# Change here to rebrand the whole app.
# ---------------------------------------------------------------------------
APP_NAME=PixShare
APP_DESCRIPTION=Discover and share beautiful moments
APP_PRIMARY_COLOR=#6C5CE7
APP_ACCENT_COLOR=#00CEC9

# Uploads
MAX_UPLOAD_MB=8
IMAGE_CACHE_SECONDS=86400
